            <column-instance column='[Calculation_0803196874592259]' derivation='Sum' name='[sum:Calculation_0803196874592259:qk]' pivot='key' type='quantitative' />
            <column-instance column='[calls_6_mnth]' derivation='Sum' name='[sum:calls_6_mnth:qk]' pivot='key' type='quantitative' />
            <column-instance column='[logons_6_mnth]' derivation='Sum' name='[sum:logons_6_mnth:qk]' pivot='key' type='quantitative' />
            <column datatype='string' name='[visit_id]' role='dimension' type='nominal' />
            <column-instance column='[date_time]' derivation='Week' name='[wk:date_time:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
