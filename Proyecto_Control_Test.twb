      <aliases enabled='yes' />
      <column caption='Completion Rate(start&amp;confirm)' datatype='real' default-format='p0.00%' name='[Calculation_0698468198817792]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF [Calculation_0698468229132299] = &quot;1&quot; THEN [client_id] END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNTD(&#13;&#10;    IF [process_step] = &quot;start&quot; THEN [client_id] END&#13;&#10;)' />
      </column>
      <column caption='Tiene Start' datatype='string' name='[Calculation_0698468208701443]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [process_step] = &quot;start&quot; THEN &quot;1&quot; END' />
      </column>
      <column aggregation='Sum' caption='Confirma' datatype='integer' name='[Calculation_0698468212772868]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [client_id] :&#13;&#10;    MAX( IIF( LOWER(TRIM([process_step])) = &quot;confirm&quot;, 1, 0 ) )&#13;&#10;}' />
      </column>
      <column caption='Filtrar SOLO los pasos válidos del funnel' datatype='boolean' name='[Calculation_0698468215406599]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='process_step IN (&quot;start&quot;, &quot;step_1&quot;, &quot;step_2&quot;, &quot;step_3&quot;, &quot;confirm&quot;)' />
      </column>
      <column caption='completion_flag_start_only' datatype='integer' name='[Calculation_0698468225593352]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [process_step] = &quot;start&quot; THEN [completion_flag] END' />
      </column>
      <column caption='Tiene Confirm' datatype='string' name='[Calculation_0698468229025802]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [process_step] = &quot;confirm&quot; THEN &quot;1&quot; END' />
      </column>
      <column caption='Tiene start_and_confirm' datatype='string' name='[Calculation_0698468229132299]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED [client_id] :&#13;&#10;    IF MAX([Calculation_0698468208701443]) = &quot;1&quot;&#13;&#10;    AND MAX([Calculation_0698468229025802]) = &quot;1&quot;&#13;&#10;    THEN &quot;1&quot;&#13;&#10;    ELSE &quot;0&quot;&#13;&#10;    END&#13;&#10;}' />
      </column>
      <column caption='Recuento de Filas' datatype='integer' name='[Calculation_0698468234776588]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column aggregation='Sum' caption='Edad Numérica' datatype='real' name='[Calculation_0698468236197901]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='FLOAT([clnt_age])' />
      </column>
      <column caption='Edad Válida' datatype='boolean' name='[Calculation_0698468238409742]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF FLOAT([clnt_age]) &gt;= 18&#13;&#10;AND FLOAT([clnt_age]) &lt;= 99&#13;&#10;THEN TRUE&#13;&#10;END' />
      </column>
      <column caption='Edad Inválida' datatype='boolean' name='[Calculation_0698468238823439]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='ISNULL(FLOAT([clnt_age]))' />
      </column>
      <column caption='Media Edad' datatype='real' name='[Calculation_0803196847620096]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_0698468236197901])' />
      </column>
      <column caption='STD Edad' datatype='real' name='[Calculation_0803196851724289]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='STDEV([Calculation_0698468236197901])' />
      </column>
      <column caption='Semana mas visitas' datatype='boolean' name='[Calculation_0803196869844994]' role='measure' type='nominal'>
        <calculation class='tableau' formula='COUNT([visit_id]) = WINDOW_MAX(COUNT([visit_id]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Totales ultimos 6 meses' datatype='integer' name='[Calculation_0803196874592259]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[calls_6_mnth] + [logons_6_mnth]' />
      </column>
      <column caption='Segundo_ok' datatype='real' name='[Calculation_0803196906954756]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[time_diff_sec]/1000' />
      </column>
