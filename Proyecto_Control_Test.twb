      <table>
        <view>
          <datasources>
            <datasource caption='df_final_limpieza' name='federated.1wjpyhd0poa32w1gy5csx0ayvj3m' />
          </datasources>
          <datasource-dependencies datasource='federated.1wjpyhd0poa32w1gy5csx0ayvj3m'>
            <column caption='Totales ultimos 6 meses' datatype='integer' name='[Calculation_0803196874592259]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[calls_6_mnth] + [logons_6_mnth]' />
            </column>
            <column datatype='integer' name='[calls_6_mnth]' role='measure' type='quantitative' />
            <column-instance column='[visit_id]' derivation='Count' name='[cnt:visit_id:qk]' pivot='key' type='quantitative' />
